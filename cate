3️⃣ AJAX call
<script>

$('#applyFilter').click(function(){

let category = $('#category').val();
let min_price = $('#min_price').val();
let max_price = $('#max_price').val();
let rating = $('#rating').val();

$.ajax({
    url: "/products",
    type: "GET",
    data: {
        category: category,
        min_price: min_price,
        max_price: max_price,
        rating: rating
    },
    success: function(response){

        let html = '';

        response.forEach(product => {

            html += `
            <div class="product">
                <h3>${product.name}</h3>
                <p>₹ ${product.price}</p>
            </div>
            `;

        });

        $('#product-list').html(html);

    }
});

});

</script>
